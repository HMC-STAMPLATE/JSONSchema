{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "$id": "https://hmc-stamplate.github.io/JSONSchema/observation_properties.schema.json",
  "title": "ObservationProperties",
  "description": "JSON object of the `properties` property of an OGC STA `Observation` entity for the STAMPLATE profile",
  "type": "object",
  "properties": {
    "@context": {
      "type": [
        "string",
        "array"
      ],
      "description": "Reference to the STAMPLATE JSON-LD context",
      "anyOf": [
        {
          "enum": [
            "https://hmc-stamplate.github.io/JSONSchema/stamplate.jsonld"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      ]
    },
    "jsonld.type": {
      "type": "string",
      "const": "ObservationProperties"
    },
    "dataSource": {
      "description": "additional information on the source of the observation, e.g., a file name",
      "type": "string"
    }
  },
  "required": [
    "@context",
    "jsonld.type"
  ],
  "additionalProperties": true
}
