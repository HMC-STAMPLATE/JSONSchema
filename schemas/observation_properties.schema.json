{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "$id": "https://hmc-stamplate.github.io/JSONSchema/observation_properties.schema.json",
  "title": "ObservationProperties",
  "description": "JSON object of the `properties` (`parameters` in STA V1) property of an OGC STA `Observation` entity for the STAMPLATE profile",
  "type": "object",
  "properties": {
    "@context": {
      "type": [
        "string",
        "array"
      ],
      "description": "reference to the STAMPLATE JSON-LD context",
      "anyOf": [
        {
          "enum": [
            "https://hmc-stamplate.github.io/JSONSchema/stamplate.jsonld"
          ]
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      ]
    },
    "jsonld.type": {
      "type": "string",
      "const": "ObservationProperties"
    },
    "dataSource": {
      "description": "additional information on the source of the observation, e.g., a file name",
      "type": "string"
    },
    "hasQualityMeasurement": {
      "type": "object",
      "description": "quality measurement of this observation according to DQV",
      "properties": {
        "jsonld.id": {
          "description": "IRI identifying this specific QualityMeasurement node",
          "$ref": "#/$defs/url"
        },
        "jsonld.type": {
          "type": "string",
          "const": "dqv:QualityMeasurement"
        },
        "qualityStatus": {
          "description": "status derived from dqv:value according to the ISO 19157 convention",
          "type": "string"
        },
        "qualityValue": {
          "description": "value according to DQV",
          "type": "string"
        },
        "qualitySchema": {
          "description": "IRI of the dqv:Dimension this quality measurement is defined in",
          "$ref": "#/$defs/url"
        },
        "qualityMethods": {
          "description": "list of IRIs of the dqv:Metric instances that use the same dqv:Dimension and were used to produce this quality measurement",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "jsonld.type": {
                "type": "string",
                "const": "Role"
              },
              "roleName": {
                "description": "name of the role the person has w.r.t. the thing, e.g., Owner",
                "type": "string"
              },
              "definition": {
                "$ref": "#/$defs/optionalUrl"
              },
              "responsiblePersons": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "jsonld.id": {
                      "description": "link to a view page of the respective entity in the source system",
                      "$ref": "#/$defs/url"
                    },
                    "jsonld.type": {
                      "type": "string",
                      "const": "Person"
                    },
                    "givenName": {
                      "type": "string"
                    },
                    "familyName": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string",
                      "pattern": "^\\S+@\\S+\\.\\S+$",
                      "minLength": 6
                    },
                    "affiliation": {
                      "$ref": "#/$defs/organization"
                    },
                    "identifier": {
                      "description": "link to a persistent identifier for the person, e.g., the ORCID",
                      "$ref": "#/$defs/optionalUrl"
                    }
                  },
                  "required": [
                    "jsonld.type"
                  ]
                }
              }
            },
            "required": [
              "jsonld.type"
            ]
          },
          "$ref": "#/$defs/url"
        }
      },
      "required": [
        "jsonld.type"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "@context",
    "jsonld.type"
  ],
  "additionalProperties": true,
  "$defs": {
    "url": {
      "type": "string",
      "pattern": "^https*://"
    }
  }
}
